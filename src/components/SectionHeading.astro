---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'center' } = Astro.props;
const centered = align === 'center';
---

<div class:list={['max-w-3xl', centered && 'mx-auto text-center']} data-reveal>
  <span class="eyebrow">{eyebrow}</span>
  <h2 class="mt-5 font-display text-[clamp(2rem,5vw,3.65rem)] font-bold leading-[1.08] tracking-[-0.035em] text-text-primary">
    {title}
  </h2>
  {description && (
    <p class:list={['mt-6 text-base leading-8 text-text-secondary sm:text-lg', centered && 'mx-auto max-w-2xl']}>
      {description}
    </p>
  )}
</div>
